server:
  port: ${PORT:8080}

spring:
  application:
    name: ${SPRING_APPLICATION_NAME:api-gateway}
  cloud:
    gateway:
      discovery:
        locator:
          enabled: true
          lower-case-service-id: true
      globalcors:
        cors-configurations:
          '[/**]':
            allowedOrigins:
              - "${FRONTEND_URL:http://localhost:5173}"
              - "${FRONTEND_ALT_URL:http://localhost:3000}"
              - "https://*.*.railway.app"
            allowedOriginPatterns:
              - "${CORS_ALLOWED_ORIGIN_PATTERN:*}"
            allowedMethods:
              - GET
              - POST
              - PUT
              - DELETE
              - OPTIONS
            allowedHeaders: "*"
            allowCredentials: true
            maxAge: 3600
      routes:
        # Auth Service — authentication and JWT
        - id: auth-service
          uri: lb://auth-service
          predicates:
            - Path=/api/auth/**

        # User Service — user management
        - id: user-service
          uri: lb://user-service
          predicates:
            - Path=/api/users/**

        # Product Service — products, categories, reviews
        - id: product-service
          uri: lb://product-service
          predicates:
            - Path=/api/products/**, /api/categories/**, /api/reviews/**

        # Order Service — orders, cart, coupons
        - id: order-service
          uri: lb://order-service
          predicates:
            - Path=/api/orders/**, /api/cart/**, /api/coupons/**

        # Payment Service
        - id: payment-service
          uri: lb://payment-service
          predicates:
            - Path=/api/payments/**

        # Agentic RAG Service (AI Advisor)
        - id: agentic-rag-service
          uri: http://agentic-rag-service:8090
          predicates:
            - Path=/api/advisor/**
          filters:
            - RewritePath=/api/advisor/(?<segment>.*), /api/$\{segment}

eureka:
  client:
    service-url:
      defaultZone: ${EUREKA_URL:http://localhost:8761/eureka/}
  instance:
    prefer-ip-address: ${EUREKA_PREFER_IP_ADDRESS:true}

jwt:
  secret: ${JWT_SECRET:pcshop-jwt-secret-key-2026-must-be-at-least-256-bits-long-for-hs256}

management:
  endpoints:
    web:
      exposure:
        include: ${MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE:health,info,gateway}
