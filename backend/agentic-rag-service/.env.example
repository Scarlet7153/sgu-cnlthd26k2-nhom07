# Runtime
APP_NAME=agentic-rag-service
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8090
LOG_LEVEL=INFO

# ReAct loop
REACT_MAX_ITERATIONS=4
REACT_TIMEOUT_SECONDS=30
MIN_DB_EVIDENCE_COUNT=2
ENABLE_SMOLAGENTS=false

# LiteLLM
LITELLM_MODEL=gpt-4o-mini
LITELLM_API_KEY=
LITELLM_BASE_URL=
LITELLM_TEMPERATURE=0.2

# MongoDB Atlas
MONGODB_URI=
MONGODB_PRODUCT_DATABASE=product_db
MONGODB_PRODUCT_COLLECTION=products
MONGODB_AGENT_DATABASE=agentic_rag_db
CHAT_HISTORIES_COLLECTION=chat_histories
PC_BUILD_SESSIONS_COLLECTION=pc_build_sessions
ATLAS_TEXT_INDEX=product_text_idx
ATLAS_VECTOR_INDEX=product_vector_idx
EMBEDDING_FIELD=embedding_vector
TEXT_SCORE_WEIGHT=0.45
VECTOR_SCORE_WEIGHT=0.55

# Embedding model (Vietnamese)
EMBEDDING_MODEL=VoVanPhuc/sup-SimCSE-VietNamese-phobert-base

# Web retrieval
WEB_SEARCH_MAX_RESULTS=5

# Build session rules
REQUIRED_BUILD_SLOTS=CPU,MAINBOARD,RAM,GPU,SSD,PSU,CASE,COOLER
